{
  "name": "kuntechs-spa",
  "version": "1.0.0",
  "description": "KunTechs Modern SPA Application",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "node backend/server.js",
    "build": "cd frontend && npm run build",
    "build:backend": "echo 'Backend is JS, no build needed'",
    "start": "node backend/server.js",
    "preview": "cd frontend && npm run preview"
  },
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
